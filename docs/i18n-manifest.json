{
  "$comment": "Drives .github/workflows/i18n-stale-check.yml. Add entries here; the workflow needs no edits. Flip 'enabled' to false to silence a language until its translations exist.",
  "languages": {
    "ko": { "label": "한국어",       "enabled": true },
    "es": { "label": "Español",      "enabled": true },
    "zh-CN": { "label": "简体中文",  "enabled": true },
    "ja": { "label": "日本語",       "enabled": true }
  },
  "docs": [
    {
      "canonical": "README.md",
      "translations": {
        "ko":    "README.ko.md",
        "es":    "README.es.md",
        "zh-CN": "README.zh-CN.md",
        "ja":    "README.ja.md"
      }
    },
    {
      "canonical": "docs/quickstart.en.md",
      "translations": {
        "ko":    "docs/quickstart.ko.md",
        "es":    "docs/quickstart.es.md",
        "zh-CN": "docs/quickstart.zh-CN.md",
        "ja":    "docs/quickstart.ja.md"
      }
    }
  ]
}
